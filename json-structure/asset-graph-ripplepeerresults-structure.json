      }
    },
    "pubkey_node": {
      "type": "string"
    },
    "publisher_list": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "server_state": {
      "type": "string"
    },
    "validator_sites": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}