  "name": "Export",
  "description": "Export schema from Asset Graph API",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "details": {
      "type": "string"
    },
    "max_payload_size": {
      "type": "int32",
      "minimum": 0
