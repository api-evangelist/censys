{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-structure/platform-serverconfig-structure.json",
  "name": "ServerConfig",
  "description": "ServerConfig schema from Censys Platform API",
  "type": "object",
