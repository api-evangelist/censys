    "max_users": {
      "type": "int32",
      "minimum": 0
    },
    "message_length": {
      "type": "int32",
      "minimum": 0
    },
    "recording_allowed": {
      "type": "boolean"
    },
    "welcome_text": {
      "type": "string"
    }
  }
}