{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-schema/platform-reputation-schema.json",
  "title": "Reputation",
  "description": "Reputation schema from Censys Platform API",
  "type": "object",
  "properties": {
    "evidence": {
      "items": {
        "$ref": "#/components/schemas/Reputation_Evidence"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "model_version": {
      "type": "string"
    },
    "score": {
      "format": "float",
      "type": "number"
    },
    "score_level": {
      "enum": [
        "",
        "benign",
        "low_risk",
        "medium_risk",
        "high_risk",
        "malicious"
      ],
      "type": "string"
    }
  },
  "additionalProperties": false
}