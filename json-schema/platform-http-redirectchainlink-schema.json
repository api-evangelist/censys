{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-schema/platform-http-redirectchainlink-schema.json",
  "title": "Http_RedirectChainLink",
  "description": "Http_RedirectChainLink schema from Censys Platform API",
  "type": "object",
  "properties": {
    "hostname": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "port": {
      "format": "int32",
      "minimum": 0,
      "type": "integer"
    },
    "reason": {
      "type": "string"
    },
    "scheme": {
      "type": "string"
    },
    "transport_protocol": {
      "enum": [
        "",
        "tcp",
        "udp",
        "icmp",
        "quic"
      ],
      "type": "string"
    }
  },
  "additionalProperties": false
}