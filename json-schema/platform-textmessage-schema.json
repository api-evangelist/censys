        "minimum": 0,
        "type": "integer"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "message": {
      "type": "string"
    },
    "session": {
      "items": {
        "format": "int32",
        "minimum": 0,
        "type": "integer"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "tree_id": {
      "items": {
        "format": "int32",
        "minimum": 0,
        "type": "integer"
      },
      "type": [
        "array",
        "null"
      ]
    }
  },
  "additionalProperties": false
