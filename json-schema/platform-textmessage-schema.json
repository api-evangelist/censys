{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-schema/platform-textmessage-schema.json",
  "title": "TextMessage",
  "description": "TextMessage schema from Censys Platform API",
  "type": "object",
