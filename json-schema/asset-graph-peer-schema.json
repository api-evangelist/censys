{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-schema/asset-graph-peer-schema.json",
  "title": "Peer",
  "description": "Peer schema from Asset Graph API",
  "type": "object",
  "properties": {
    "ip": {
      "type": "string"
    },
    "port": {
      "format": "int64",
      "type": "integer"
    },
    "public_key": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "additionalProperties": false
}