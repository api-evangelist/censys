{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/censys/refs/heads/main/json-schema/asset-graph-serverconfig-schema.json",
  "title": "ServerConfig",
  "description": "ServerConfig schema from Asset Graph API",
  "type": "object",
  "properties": {
    "allow_html": {
      "type": "boolean"
    },
    "image_message_length": {
      "format": "int32",
      "minimum": 0,
      "type": "integer"
    },
    "max_bandwidth": {
      "format": "int32",
      "minimum": 0,
      "type": "integer"
    },
    "max_users": {
      "format": "int32",
      "minimum": 0,
      "type": "integer"
    },
    "message_length": {
      "format": "int32",
      "minimum": 0,
      "type": "integer"
    },
    "recording_allowed": {
      "type": "boolean"
    },
    "welcome_text": {
      "type": "string"
    }
  },
  "additionalProperties": false
}